{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "tsc": {
      "dependsOn": ["^tsc"]
    }
  },
  "globalEnv": [
    "AI_IMPORT_SERVICE_URL",
    "AI_IMPORT_SERVICE_SECRET",
    "AI_IMPORT_PROVIDER",
    "AI_IMPORT_MODEL_REPO",
    "AI_IMPORT_MODEL_QUANT",
    "AI_IMPORT_MODEL_FILE",
    "AI_IMPORT_MODEL_SHA256",
    "AI_IMPORT_MODEL_DOWNLOAD_URL",
    "AI_IMPORT_MODEL_PATH",
    "AI_IMPORT_LLAMA_SERVER_PATH",
    "AI_IMPORT_CONTEXT_SIZE",
    "AI_IMPORT_MAX_TOKENS",
    "AI_IMPORT_KEEP_SERVER_ALIVE_MS",
    "DEEPSEEK_API_KEY",
    "DEEPSEEK_MODEL",
    "GITHUB_RELEASES_TOKEN",
    "GITHUB_TOKEN",
    "REDIS_URL"
  ]
}
