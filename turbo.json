{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "tasks": {
    "dev": {
      "cache": false,
      "persistent": true
    },
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"]
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    },
    "tsc": {
      "dependsOn": ["^tsc"]
    }
  },
  "globalEnv": ["AI_IMPORT_KEY", "AI_IMPORT_SERVICE_URL", "AI_IMPORT_SERVICE_API_KEY"]
}
