{
  "name": "@repo/ui",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "tsc": "tsc --noEmit"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./primitives": {
      "types": "./src/primitives/index.ts",
      "default": "./src/primitives/index.ts"
    },
    "./primitives/*": {
      "types": "./src/primitives/*.tsx",
      "default": "./src/primitives/*.tsx"
    },
    "./lib/utils": {
      "types": "./src/lib/utils.ts",
      "default": "./src/lib/utils.ts"
    },
    "./hooks/use-mobile": {
      "types": "./src/hooks/use-mobile.ts",
      "default": "./src/hooks/use-mobile.ts"
    },
    "./hooks/use-toast": {
      "types": "./src/hooks/use-toast.ts",
      "default": "./src/hooks/use-toast.ts"
    }
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "react-router": ">=7"
  },
  "dependencies": {
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-select": "^2.2.5",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.14",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.563.0",
    "radix-ui": "^1.4.3",
    "tailwind-merge": "^3.4.0"
  },
  "devDependencies": {
    "@repo/ts-config": "workspace:*",
    "typescript": "^5.3.3"
  }
}
