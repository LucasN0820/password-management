{
  "name": "password-desktop",
  "version": "1.0.0",
  "description": "A secure password manager built with Electron and React",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "pack": "yarn build && electron-builder --dir",
    "dist": "yarn build && electron-builder",
    "dist:mac": "yarn build && electron-builder --mac",
    "dist:win": "yarn build && electron-builder --win",
    "dist:linux": "yarn build && electron-builder --linux",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-rebuild",
    "preview": "vite preview",
    "tsc": "tsc --noEmit",
    "lint": "eslint ."
  },
  "dependencies": {
    "@repo/db": "workspace:*",
    "@repo/ui": "workspace:*",
    "@tailwindcss/vite": "^4.1.18",
    "@types/better-sqlite3": "^7.6.13",
    "autoprefixer": "^10.4.24",
    "better-sqlite3": "^12.6.2",
    "framer-motion": "^12.34.0",
    "lucide-react": "^0.563.0",
    "postcss": "^8.5.6",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^7.13.0",
    "tailwindcss": "^4.1.18",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/ts-config": "workspace:*",
    "@types/node": "^20.11.24",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "29.4.6",
    "electron-builder": "^24.12.0",
    "electron-rebuild": "^3.2.9",
    "eslint-config-sheriff": "^31.3.0",
    "npm-run-all": "^4.1.5",
    "shadcn": "^3.8.4",
    "tw-animate-css": "^1.4.0",
    "vite": "^5.1.4",
    "vite-plugin-electron": "^0.28.2",
    "vite-plugin-electron-renderer": "^0.14.5"
  }
}
